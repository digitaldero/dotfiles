root = true

[**.js]
indent_style = space
indent_size = 2
max_preserve_newlines = 2

[**.json]
indent_style = space
indent_size = 2
max_preserve_newlines = 2

[**.jsx]
e4x = true
indent_style = space
indent_size = 2
max_preserve_newlines = 2

[**.css]
indent_style = space
indent_size = 2
max_preserve_newlines = 2

[**.html]
;vim:brace_style=expand
indent_style = space
indent_size = 2
max_preserve_newlines = 2
