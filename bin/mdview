#!/bin/bash

# Ensure a markdown file was provided
if [ -z "$1" ] || [ ! -f "$1" ]; then
    echo "Usage: mdview <file.md>"
    exit 1
fi

# Define paths for temporary HTML file
TMP_HTML=$(mktemp /tmp/mdview_XXXXXX.html)

# 1. Convert MD to HTML and embed the stylesheet inline
pandoc "$1" -f commonmark+hard_line_breaks+pipe_tables --css=$HOME/.pandoc/epic.css -s -o "$TMP_HTML"

# 2. Open the file directly in Google Chrome
google-chrome "$TMP_HTML" &

# 3. Give Chrome a brief moment to read the file before deleting it
sleep 1
rm "$TMP_HTML"

