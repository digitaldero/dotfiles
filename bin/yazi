#!/bin/bash
# yazi wrapper - forces Kitty keyboard protocol off
# This is required for reliable <F9>, <F12>, and other function keys in yazi.
#
# Without this, Kitty's enhanced keyboard protocol sends different sequences
# for F-keys that yazi's input parser often doesn't recognize as <F9> etc.

REAL_YAZI="$HOME/.local/bin/yazi"

# Force legacy keyboard behavior so symbolic keys like <F9> work
exec env KITTY_KB_PROTOCOL=0 "$REAL_YAZI" "$@"
