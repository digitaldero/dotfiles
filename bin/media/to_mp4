#!/bin/bash
# Convert video to MP4 (H.264 + AAC)

if [ -z "$1" ]; then
    echo "Usage: to_mp4 <video_file>"
    exit 1
fi

input="$1"

if [ ! -f "$input" ]; then
    dunstify -u critical "to_mp4" "File not found: $input"
    exit 1
fi

dir=$(dirname "$input")
filename=$(basename "$input")
name="${filename%.*}"
output="$dir/${name}.mp4"

ffmpeg -i "$input" -c:v libx264 -c:a aac -b:a 192k -movflags +faststart "$output" -y 2>/dev/null

if [ $? -eq 0 ]; then
    dunstify -u normal "to_mp4" "Converted: $(basename "$output")"
else
    dunstify -u critical "to_mp4" "Failed to convert: $filename"
fi
